# Modal UI 服务端口
AI_TOOLKIT_UI_PORT=8675

# Modal GPU 型号，例如 L4 / A10G / A100
AI_TOOLKIT_GPU=L4

# Modal 函数超时时间（秒）
AI_TOOLKIT_TIMEOUT=86400

# UI 持久化数据 Volume 名称
AI_TOOLKIT_UI_VOLUME=ai-toolkit-ui-data

# 数据集 Volume 名称
AI_TOOLKIT_DATA_VOLUME=ai-toolkit-datasets

# Volume 自动提交间隔（秒）
AI_TOOLKIT_VOLUME_COMMIT_INTERVAL=30

# 可选：UI 登录密码，留空则不启用
AI_TOOLKIT_AUTH=

# 可选：启动时自动同步到 Modal 数据集 Volume 的本地目录
AI_TOOLKIT_LOCAL_DATA_FOLDER=./data

# 可选：仅首次补充导入的数据目录；目标数据集已存在时不会覆盖
AI_TOOLKIT_LOCAL_DATASET_SOURCE=

# 可选：本地训练配置目录，会挂载到容器 /root/local_configs
AI_TOOLKIT_LOCAL_CONFIG_DIR=./config

# 训练任务默认使用的配置文件
# 如果是相对路径，则相对于 AI_TOOLKIT_LOCAL_CONFIG_DIR 解析
# 多个配置可用逗号分隔
AI_TOOLKIT_TRAIN_CONFIG=train_lora_flux_dev_modal_minimal.yaml

# 训练附加参数，例如 --sample_every_n_steps 100
AI_TOOLKIT_TRAIN_EXTRA_ARGS=

# 训练函数超时时间（秒）
AI_TOOLKIT_TRAIN_TIMEOUT=7200

# 训练输出 Volume 名称
AI_TOOLKIT_MODEL_VOLUME=ai-toolkit-models

# 容器内训练输出目录
AI_TOOLKIT_TRAIN_OUTPUT_DIR=/root/ai-toolkit/modal_output
